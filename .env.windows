# =========================
# HYPERSPACE / HOST
# =========================
TZ=Europe/Rome
HOST_ROLE=primary-brain
HOST_NAME=changeme-host
LOG_LEVEL=info

# Base paths Windows
HS_ROOT=C:\HyperSpace
HS_CONFIG_DIR=C:\HyperSpace\config
HS_DATA_DIR=C:\HyperSpace\data
HS_MEMORY_DIR=C:\HyperSpace\memory
HS_LOG_DIR=C:\HyperSpace\logs

# =========================
# OLLAMA HOST (Windows host)
# =========================
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_CHAT_BASE_URL=http://host.docker.internal:11434/api
OLLAMA_RAW_BASE_URL=http://host.docker.internal:11434

# General model
HS_MODEL_GENERAL=qwen3-14b-uncensored
HS_MODEL_GENERAL_FALLBACK=qwen3-14b-abliterated

# Coder model
HS_MODEL_CODER=qwen2.5-coder-14b-abliterated
HS_MODEL_CODER_FALLBACK=qwen2.5-coder-14b-instruct

# Routing / behavior
HS_DEFAULT_MODEL_ROLE=general
HS_ENABLE_MODEL_ROUTING=true
HS_ENABLE_CODE_AGENT=true
HS_ENABLE_MEMORY=true
HS_ENABLE_TOOL_USE=true

# =========================
# OLLAMA RUNTIME TUNING
# =========================
OLLAMA_KEEP_ALIVE=12h
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_QUEUE=64
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_LOAD_TIMEOUT=15m
OLLAMA_REQUEST_TIMEOUT=300
OLLAMA_CONTEXT_LENGTH=8192

# =========================
# NETWORK
# =========================
TS_ENABLED=true
TS_HOSTNAME=changeme-host
TS_ACCEPT_DNS=true
TS_USE_FUNNEL=false
TS_USE_EXIT_NODE=false

# =========================
# CONTAINERS
# =========================
COMPOSE_PROJECT_NAME=hyperspace
RESTART_POLICY=unless-stopped

# =========================
# SECURITY
# =========================
EXPOSE_PUBLIC_PORTS=false
BIND_LOCALHOST_ONLY=true
ALLOW_TAILSCALE_REMOTE=true
