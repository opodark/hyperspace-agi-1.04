# HyperSpace AGI v0.2 — Environment Config
# Copia in .env e personalizza. Generato da setup.sh / setup.ps1.

# ── Node ───────────────────────────────────────────────────────
NODE_HOSTNAME=localhost
NODE_TIER=leaf
VRAM_GB=0.0

# Peer iniziali (mesh bootstrap, separati da virgola)
# Es: BOOT_PEERS=192.168.1.11:8084,192.168.1.12:8084
BOOT_PEERS=

# Lista nodi monitorati dal control-plane
NODE_ENDPOINTS=node:8084

# ── Inferenza LLM ──────────────────────────────────────────────────
# Backend: ollama | lmstudio | ollama-docker
INFERENCE_BACKEND=ollama

# Ollama nativo sul host (macOS/Linux):
# OLLAMA_URL=http://host.docker.internal:11434
#
# LM Studio (porta default 1234):
# OLLAMA_URL=http://host.docker.internal:1234
# LMS_URL=http://host.docker.internal:1234
#
# Ollama nativo Linux (docker0):
# OLLAMA_URL=http://172.17.0.1:11434
#
# Ollama in Docker (legacy, usa --profile with-ollama):
# OLLAMA_URL=http://ollama:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# URL LM Studio (usato solo se INFERENCE_BACKEND=lmstudio)
LMS_URL=

# ── Legacy Authority ─────────────────────────────────────────────────
AUTHORITY_ENABLED=false
AUTHORITY_URL=http://authority:8080

# ── Security ─────────────────────────────────────────────────────
WEBUI_SECRET_KEY=hyperspace-secret-change-me
