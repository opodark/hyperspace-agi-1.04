# ============================================================
# HyperSpace AGI v1.02 — .env.example
# Copia in .env e modifica solo le variabili che ti riguardano.
# Il registro pubblico è già configurato: i peer vengono
# scoperti automaticamente al boot — non serve BOOT_PEERS.
# ============================================================

# ── OBBLIGATORIO ────────────────────────────────────────────
# Il tuo endpoint pubblico (ngrok, tailscale funnel, VPS, ecc.)
# I peer della mesh lo usano per contattarti.
PUBLIC_ENDPOINT=https://il-tuo-tunnel.ngrok-free.app

# ── INFERENCE ───────────────────────────────────────────────
# URL del tuo backend di inferenza locale (Ollama o LM Studio)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=

# ── REGISTRY ────────────────────────────────────────────────
# Registry pubblico fisso — non cambiarlo se usi la mesh pubblica.
# Cambialo solo se vuoi una mesh privata.
REGISTRY_PUBLIC_URL=https://sanctuary-mower-plated.ngrok-free.dev

# ── OPZIONALI ───────────────────────────────────────────────
# Tier forzato del nodo: root | hub | leaf (lascia vuoto = auto)
# NODE_TIER=hub

# VRAM del tuo GPU in GB (0 = CPU only, auto-detected se nvidia-smi presente)
# VRAM_GB=8

# Secondi prima che un peer venga marcato stale (default 120)
# PEER_MAX_AGE_S=120

# Secondi TTL nodi nel registry (default 300)
# NODE_TTL=300

# Porta locale del nodo (default 8084)
# NODE_PORT=8084

# Firma crittografica inter-nodo (default true — non disabilitare in produzione)
# SIGN_REQUESTS=true

# Peer manuali da contattare al boot (opzionale — auto-discovery se vuoto)
# BOOT_PEERS=https://peer1.ngrok-free.app,https://peer2.ngrok-free.app

# Control plane URL (solo se hai un CP separato dalla mesh pubblica)
# CONTROL_PLANE_URL=https://il-tuo-cp.ngrok-free.app

# Porta locale del wizard di primo avvio (default 8088, http://localhost:8088)
# ONBOARDING_PORT=8088

# Etichetta libera per identificare a colpo d'occhio a cosa serve il nodo
# NODE_SPECIALIZATION=generalist

# Emoji che rappresenta il nodo nelle dashboard
# NODE_AVATAR=🤖

# ── FALLBACK ESTERNO (OmniRoute) ───────────────────────────────
# Ultimo livello di fallback quando nessun nodo della mesh (locale o
# federato) può rispondere: inoltra la richiesta a OmniRoute
# (https://github.com/diegosouzapw/OmniRoute), gateway verso 278+ provider
# AI esterni. Funziona già senza configurazione (provider free-tier di
# default). Per collegare provider propri: apri http://<host>:20128 dalla
# dashboard e copia la API key da Endpoints.
# OMNIROUTE_ENABLED=true
# OMNIROUTE_API_KEY=
# OMNIROUTE_MODEL=auto
