# =============================================================
# HyperSpace AGI v0.2 — Configurazione
# Copia in .env e personalizza per ogni macchina
# =============================================================

# --- Ollama / LLM backend ---
# URL raggiungibile DAI CONTAINER Docker
# macOS:  http://host.docker.internal:11434
# Linux:  http://172.17.0.1:11434
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# --- Identità nodo ---
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=leaf
VRAM_GB=0.0

# --- Endpoint pubblico di questo nodo ---
# URL con cui gli altri nodi raggiungono questo nodo dall'esterno.
#
# [MAC - seed ngrok]
# PUBLIC_ENDPOINT=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
#
# [UBUNTU - seed ngrok (dominio da ottenere su ngrok dashboard)]
# PUBLIC_ENDPOINT=https://TUO-DOMINIO-UBUNTU.ngrok-free.dev
#
# Lascia vuoto se il nodo non ha URL pubblico (solo LAN/Docker)
PUBLIC_ENDPOINT=

# --- Seed / Boot peers (P2P) ---
# Peer iniziali per entrare nella mesh via P2P.
# Ogni nodo mette qui gli altri seed.
#
# [MAC]: conosce Ubuntu seed
# BOOT_PEERS=https://TUO-DOMINIO-UBUNTU.ngrok-free.dev
#
# [UBUNTU]: conosce Mac seed
# BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev
#
# Più seed: BOOT_PEERS=https://seed1.ngrok-free.dev,https://seed2.ngrok-free.dev
BOOT_PEERS=

# --- Control Plane URL ---
# URL del control-plane a cui il nodo si auto-registra.
#
# [Nodo locale Mac, stesso stack Docker]
# CONTROL_PLANE_URL=http://control-plane:8085
#
# [Nodo Ubuntu remoto -> control-plane Mac via Tailscale]
# CONTROL_PLANE_URL=http://100.81.234.102:8085
#
# [Nodo esterno -> control-plane Mac via ngrok (se esponi anche 8085)]
# CONTROL_PLANE_URL=https://ALTRO-DOMINIO.ngrok-free.dev
CONTROL_PLANE_URL=http://control-plane:8085

# --- Control Plane: nodi pre-configurati ---
# Aggiornato automaticamente via /mesh/announce
# Puoi pre-popolare con URL ngrok dei seed
NODE_ENDPOINTS=node:8084

# --- Open WebUI ---
WEBUI_SECRET_KEY=hyperspace-secret-change-me

# --- Inference backend (usato da setup.sh) ---
INFERENCE_BACKEND=ollama
