# =============================================================
# HyperSpace AGI v1.02 — .env per Ubuntu (hub/authority)
# Questa macchina è un HUB: accetta announce da nodi esterni
# e si annuncia all'hub Mac via ngrok.
# =============================================================

# Ollama (Ubuntu: Ollama nativo)
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_MODEL=phi3

# Identità nodo
NODE_HOSTNAME=node
NODE_PORT=8084
NODE_TIER=hub
VRAM_GB=0.0

# Endpoint pubblico di QUESTO nodo — url ngrok dell'Ubuntu
PUBLIC_ENDPOINT=https://sanctuary-mower-plated.ngrok-free.dev

# Boot peers: l'Ubuntu si annuncia all'hub Mac all'avvio
BOOT_PEERS=https://charlesetta-haptical-unconcentratedly.ngrok-free.dev

# Control-plane locale
CONTROL_PLANE_URL=http://control-plane:8085

# Registry locale
REGISTRY_URL=http://registry:8086
REGISTRY_PORT=8086

# Nodi noti al control-plane locale:
# - node:8084 = nodo locale
# - ngrok Mac = nodo remoto Mac (topology federata)
NODE_ENDPOINTS=node:8084,https://charlesetta-haptical-unconcentratedly.ngrok-free.dev

# Heartbeat ogni 15s
HEARTBEAT_EVERY=15
HEARTBEAT_INTERVAL=15
NODE_TTL=60

# Firma inter-nodo abilitata
SIGN_REQUESTS=true

# Open WebUI
WEBUI_SECRET_KEY=hyperspace-secret-change-me

INFERENCE_BACKEND=ollama
